  "screenshots": [

    {
      "src": "./icons/screenshot-wide.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Vista de partidos del Mundial 2026"
    },

    {
      "src": "./icons/screenshot-narrow.png",
      "sizes": "750x1334",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Clasificación familiar en móvil"
    }
  ],

  "shortcuts": [

    {
      "name": "Ver Partidos",
      "short_name": "Partidos",
      "description": "Acceso rápido a los partidos",
      "url": "./?view=matches",
