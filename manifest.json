          "type": "image/png"
        }
      ]
    },

    {
      "name": "Clasificación",
      "short_name": "Clasif.",
      "description": "Ver tabla de clasificación",
      "url": "./?view=leaderboard",
      "icons": [
        {
          "src": "./icons/shortcut-leaderboard.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },

    {
      "name": "Añadir Participante",
