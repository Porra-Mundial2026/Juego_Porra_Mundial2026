{
  "id": "./",

  "name": "World Cup 2026 • Family Predictor",

  "short_name": "WC 2026",

  "description": "Porra familiar del Mundial 2026 con resultados en vivo, clasificación automática y experiencia Apple Ultra.",

  "lang": "es",

  "dir": "ltr",

  "start_url": "./",

  "scope": "./",

  "display": "standalone",

  "display_override": [
    "standalone",
    "minimal-ui",
    "browser"
  ],

  "orientation": "portrait-primary",

  "background_color": "#020617",

  "theme_color": "#020617",

  "categories": [
    "sports",
    "games",
    "entertainment"
  ],

  "prefer_related_applications": false,

  "launch_handler": {
    "client_mode": "navigate-existing"
  },

  "edge_side_panel": {
    "preferred_width": 420
  },

  "icons": [

