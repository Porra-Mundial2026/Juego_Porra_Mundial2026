      "sizes": "96x96",
      "type": "image/png",
      "purpose": "any"
    },

    {
      "src": "./icons/icon-128.png",
      "sizes": "128x128",
      "type": "image/png",
      "purpose": "any"
    },

    {
      "src": "./icons/icon-144.png",
      "sizes": "144x144",
      "type": "image/png",
      "purpose": "any"
    },

    {
      "src": "./icons/icon-152.png",
      "sizes": "152x152",
